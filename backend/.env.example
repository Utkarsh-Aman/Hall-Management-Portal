# =============================================================================
# Hall 12 Marathas Portal — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend URL (for CORS — must match exactly. Can be a comma-separated list for multiple URLs)
FRONTEND_URL=http://localhost:3000,https://hmp.hall12iitk.in

# SMTP (leave empty for console-log backend in development)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hall12.iitk.ac.in
